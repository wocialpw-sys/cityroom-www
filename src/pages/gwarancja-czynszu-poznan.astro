---
import { getEntry, render } from "astro:content";
import Base from "../layouts/Base.astro";
import {
  organizationSchema,
  localBusinessSchema,
  serviceSchema,
  faqPageSchema,
  breadcrumbSchema,
} from "../lib/schema";

const entry = await getEntry("pages", "gwarancja-czynszu-poznan");
if (!entry) {
  throw new Error("Content entry not found: gwarancja-czynszu-poznan");
}

const { Content } = await render(entry);
const fm = entry.data;
const pageUrl = `https://cityroom.pl/${fm.slug}/`;

/* JSON-LD schemas — kolejność wstrzykiwania do <head> */
const schemas = [
  organizationSchema(),
  localBusinessSchema({ rating: 4.9, reviewCount: 103 }),
  serviceSchema({
    serviceName: fm.serviceData?.serviceName ?? "Gwarancja czynszu",
    description: fm.description,
    url: pageUrl,
    areaServed: fm.serviceData?.areaServed,
  }),
  faqPageSchema(fm.faq),
  breadcrumbSchema([
    { name: "Strona główna", url: "/" },
    { name: "Zarządzanie najmem Poznań", url: "/zarzadzanie-najmem-poznan/" },
    { name: "Gwarancja czynszu Poznań", url: `/${fm.slug}/` },
  ]),
];
---

<Base
  title={fm.title}
  description={fm.description}
  canonical={pageUrl}
  noindex={true}
>
  {
    schemas.map((s) => (
      <script
        type="application/ld+json"
        slot="schema"
        set:html={JSON.stringify(s)}
      />
    ))
  }

  <main class="relative min-h-screen overflow-hidden bg-[var(--cr-paper)]">
    {/* Soft brand gradient blob, top-right */}
    <div
      class="pointer-events-none absolute top-0 right-0 h-[640px] w-[640px] -translate-y-1/3 translate-x-1/4 rounded-full opacity-[0.06]"
      style="background: var(--cr-gradient-radial); filter: blur(80px);"
      aria-hidden="true"
    >
    </div>

    <header
      class="relative mx-auto flex max-w-[1200px] items-center justify-between px-6 pt-8 lg:px-12"
    >
      <a
        href="/"
        class="inline-flex items-center"
        aria-label="Cityroom — strona główna"
      >
        <img
          src="/brand/logo.png"
          alt="Cityroom"
          height="24"
          class="h-6 w-auto"
        />
      </a>
      <span class="eyebrow">Stage · v0.0.1</span>
    </header>

    {/* Hero section — eyebrow → display → lead → CTA */}
    <section
      class="relative mx-auto max-w-[1200px] px-6 pt-12 pb-16 lg:px-12 lg:pt-20"
    >
      <nav aria-label="Ścieżka" class="mb-6 text-sm text-[var(--cr-ink-30)]">
        <a href="/" class="hover:text-[var(--cr-blue-600)]">Strona główna</a>
        <span class="mx-2">→</span>
        <a
          href="/zarzadzanie-najmem-poznan/"
          class="hover:text-[var(--cr-blue-600)]"
        >
          Zarządzanie najmem Poznań
        </a>
        <span class="mx-2">→</span>
        <span>Gwarancja czynszu</span>
      </nav>

      <p class="eyebrow mb-5">Dla właścicieli mieszkań</p>

      <h1 class="display max-w-[20ch]">
        Gwarancja <span class="text-gradient">czynszu</span> w Poznaniu.
      </h1>

      <p class="lead mt-7 max-w-[55ch]">
        Stały przelew 10. dnia każdego miesiąca, niezależnie od obłożenia. Od
        2017 roku, dla 130 mieszkań w Poznaniu, ze średnią oceną 4,9 / 103
        opinie w Google.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-3">
        {
          fm.heroCta?.primary && (
            <a
              href={fm.heroCta.primary.href}
              class="inline-flex items-center justify-center rounded-md bg-[var(--cr-ink)] px-6 py-3 text-sm font-medium text-white transition hover:bg-[var(--cr-ink-10)] active:scale-[0.98]"
              style={`box-shadow: var(--shadow-glow);`}
            >
              {fm.heroCta.primary.label}
            </a>
          )
        }
        {
          fm.heroCta?.secondary && (
            <a
              href={fm.heroCta.secondary.href}
              class="inline-flex items-center justify-center rounded-md border border-[var(--cr-line-2)] bg-white px-6 py-3 text-sm font-medium text-[var(--cr-ink)] transition hover:border-[var(--cr-ink)] active:scale-[0.98]"
            >
              {fm.heroCta.secondary.label}
            </a>
          )
        }
      </div>
    </section>

    {/* Markdown content — rendered with .prose styling */}
    <article class="relative mx-auto max-w-[1200px] px-6 lg:px-12">
      <div class="prose">
        <Content />
      </div>
    </article>

    {/* FAQ section — FAQPage schema mirror w widocznym HTML */}
    {
      fm.faq.length > 0 && (
        <section class="relative mx-auto max-w-[1200px] px-6 pt-20 lg:px-12">
          <p class="eyebrow mb-4">FAQ</p>
          <h2
            class="font-[var(--font-display)] text-3xl font-medium text-[var(--cr-ink)] lg:text-4xl"
            style="letter-spacing: -0.015em;"
          >
            Najczęstsze pytania o gwarancję czynszu
          </h2>
          <div class="mt-10 max-w-[800px] divide-y divide-[var(--cr-line)] border-t border-b border-[var(--cr-line)]">
            {fm.faq.map((item) => (
              <details class="group py-6">
                <summary class="flex cursor-pointer list-none items-start justify-between gap-6 font-[var(--font-display)] text-lg font-medium text-[var(--cr-ink)] transition group-hover:text-[var(--cr-blue-600)]">
                  <span class="flex-1" style="text-wrap: balance;">
                    {item.question}
                  </span>
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 20 20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    class="mt-1 shrink-0 transition group-open:rotate-45"
                    aria-hidden="true"
                  >
                    <path d="M10 4v12M4 10h12" />
                  </svg>
                </summary>
                <div class="mt-4 max-w-[70ch] text-[var(--cr-ink-10)]">
                  <p style="text-wrap: pretty;">{item.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </section>
      )
    }

    {/* Powiązane — 3 cluster pages */}
    {
      fm.relatedPages.length > 0 && (
        <section class="relative mx-auto max-w-[1200px] px-6 pt-20 pb-20 lg:px-12">
          <p class="eyebrow mb-4">Powiązane</p>
          <h2
            class="font-[var(--font-display)] text-3xl font-medium text-[var(--cr-ink)] lg:text-4xl"
            style="letter-spacing: -0.015em;"
          >
            Co warto przeczytać dalej
          </h2>
          <div class="mt-10 grid gap-6 md:grid-cols-3">
            {fm.relatedPages.map((rp) => (
              <a
                href={`/${rp.slug}/`}
                class="group block rounded-[var(--r-md)] border border-[var(--cr-line)] bg-white p-7 transition hover:-translate-y-0.5 hover:border-[var(--cr-line-2)]"
                style="transition-property: transform, border-color; transition-duration: 200ms;"
              >
                <h3
                  class="font-[var(--font-display)] text-xl font-medium text-[var(--cr-ink)] group-hover:text-[var(--cr-blue-600)]"
                  style="text-wrap: balance;"
                >
                  {rp.title}
                </h3>
                <span class="mt-4 inline-flex items-center gap-1 text-sm text-[var(--cr-ink-30)] group-hover:text-[var(--cr-blue-600)]">
                  Czytaj
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 14 14"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    aria-hidden="true"
                    class="transition group-hover:translate-x-1"
                  >
                    <path d="M5 3l4 4-4 4M2 7h7" />
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    {/* CTA section — final */}
    <section
      class="relative mx-auto max-w-[1200px] border-t border-[var(--cr-line)] px-6 py-20 lg:px-12"
    >
      <div class="grid gap-8 md:grid-cols-2 md:items-center">
        <div>
          <p class="eyebrow mb-4">Następny krok</p>
          <h2
            class="font-[var(--font-display)] text-3xl font-medium text-[var(--cr-ink)] lg:text-4xl"
            style="letter-spacing: -0.015em; text-wrap: balance;"
          >
            Zobacz, ile dla Twojego mieszkania.
          </h2>
          <p class="mt-5 max-w-[55ch] text-[var(--cr-ink-10)]">
            Wycena jest bezpłatna i niezobowiązująca. Sprawdzasz konkretną kwotę,
            a nie przedział — i decydujesz spokojnie, co z nią zrobić.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 md:justify-end">
          <a
            href="https://wycena.cityroom.pl/"
            class="inline-flex items-center justify-center rounded-md bg-[var(--cr-ink)] px-6 py-3 text-sm font-medium text-white transition hover:bg-[var(--cr-ink-10)] active:scale-[0.98]"
          >
            Wycena Twojego mieszkania
          </a>
          <a
            href="/o-nas/#kontakt"
            class="inline-flex items-center justify-center rounded-md border border-[var(--cr-line-2)] bg-white px-6 py-3 text-sm font-medium text-[var(--cr-ink)] transition hover:border-[var(--cr-ink)] active:scale-[0.98]"
          >
            Umów spokojną rozmowę
          </a>
        </div>
      </div>
    </section>

    {/* Footer — minimal stage */}
    <footer
      class="relative mx-auto max-w-[1200px] border-t border-[var(--cr-line)] px-6 py-10 lg:px-12"
    >
      <div class="flex flex-col gap-4 text-sm text-[var(--cr-ink-30)] md:flex-row md:items-center md:justify-between">
        <span>© Cityroom Sp. z o.o. — Poznań</span>
        <span class="mono">Stage · melawini.pl</span>
      </div>
    </footer>
  </main>
</Base>
